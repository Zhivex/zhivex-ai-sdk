{
  "name": "zhivex-ai-sdk",
  "private": true,
  "description": "TypeScript monorepo for a unified AI provider SDK for Bun and Node.",
  "type": "module",
  "packageManager": "bun@1.3.7",
  "engines": {
    "node": ">=18.18.0",
    "bun": ">=1.3.7"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "changeset": "changeset",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "version-packages": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  }
}
