{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@zhivex-ai/core": ["./packages/core/src/index.ts"],
      "@zhivex-ai/openai": ["./packages/openai/src/index.ts"],
      "@zhivex-ai/anthropic": ["./packages/anthropic/src/index.ts"],
      "@zhivex-ai/gemini": ["./packages/gemini/src/index.ts"],
      "@zhivex-ai/sdk": ["./packages/sdk/src/index.ts"]
    }
  }
}
